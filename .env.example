# MoodWave / 树莓派局域网配置
MOODWAVE_HOST=0.0.0.0
MOODWAVE_API_PORT=8765
MOODWAVE_WEB_PORT=8080
MOODWAVE_WEB_ORIGIN=http://192.168.2.33:8080

# 旧变量仍兼容，保留给历史部署
MARKRADIO_HOST=0.0.0.0
MARKRADIO_API_PORT=8765
MARKRADIO_WEB_PORT=8080
MARKRADIO_WEB_ORIGIN=http://192.168.2.33:8080

# Steam Deck 本机安装推荐：
# MOODWAVE_HOST=127.0.0.1
# MOODWAVE_PORT=38765
# MOODWAVE_WEB_PORT=38080
# APP_MODE=steamdeck

# AI 大脑：默认 DeepSeek，OpenAI-compatible
AI_PROVIDER=deepseek
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
AI_API_KEY=
DEEPSEEK_API_KEY=

# 可选：OpenAI GPT-5.5
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Fish Audio 授权音色
FISH_AUDIO_API_KEY=
FISH_AUDIO_VOICE_ID=
FISH_AUDIO_API_BASE=https://api.fish.audio

# OpenWeather，可不填，缺省进入本地上下文降级
OPENWEATHER_API_KEY=
OPENWEATHER_CITY=

# 网易云 API，可先不填，使用 Demo 歌单
NETEASE_API_BASE=

# Steam Deck 本地音乐目录，可选
MUSIC_DIR=
ENABLE_TTS=true
ENABLE_WEATHER=true
ENABLE_HOLIDAY=true
ENABLE_LOCATION=true
